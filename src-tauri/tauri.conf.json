{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Minibee-Viewer",
  "identifier": "com.pantera.minibee-viewer",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Minibee Viewer",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; media-src 'self' blob: http: https:; connect-src 'self' ipc: http://ipc.localhost; font-src 'self' data:; object-src 'none'; base-uri 'self'; frame-src 'none'; form-action 'none'"
    }
  },
  "bundle": {
    "publisher": "Pantera Polnocy",
    "homepage": "https://github.com/PanteraPolnocy/Minibee-Viewer",
    "shortDescription": "Minimalist client for Second Life",
    "longDescription": "A lightweight buzz into the infinite grid.",
    "category": "SocialNetworking",
    "active": true,
    "targets": "all",
    "licenseFile": "../LICENSE",
    "resources": {
      "../LICENSE": "LICENSE",
      "../README.md": "README.md"
    },
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": "5da9b8eff96084ae3b29b40ea4cd3f2f84d1934c",
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
